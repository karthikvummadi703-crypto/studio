/**
 * ai-cache.ts
 * In-memory + sessionStorage cache for AI responses.
 * Prevents duplicate Genkit API calls for identical prompts.
 * Improves efficiency and reduces cost.
 */

interface CacheEntry {
  response: string;
  timestamp: number;
  ttlMs: number;
}

const CACHE_PREFIX = 'ecopulse_ai_cache_';
const DEFAULT_TTL_MS = 5 * 60 * 1000; // 5 minutes

// In-memory cache (faster, cleared on page refresh)
const memoryCache = new Map<string, CacheEntry>();

function hashKey(input: string): string {
  // Simple djb2 hash for cache keys
  let hash = 5381;
  for (let i = 0; i < input.length; i++) {
    hash = (hash << 5) + hash + input.charCodeAt(i);
    hash = hash & hash; // Convert to 32-bit integer
  }
  return Math.abs(hash).toString(36);
}

export function getCachedAIResponse(prompt: string): string | null {
  const key = hashKey(prompt);
  const now = Date.now();

  // Check memory cache first
  const memEntry = memoryCache.get(key);
  if (memEntry && now - memEntry.timestamp < memEntry.ttlMs) {
    return memEntry.response;
  }

  // Check sessionStorage (survives component remounts)
  if (typeof window !== 'undefined') {
    try {
      const stored = sessionStorage.getItem(`${CACHE_PREFIX}${key}`);
      if (stored) {
        const entry: CacheEntry = JSON.parse(stored);
        if (now - entry.timestamp < entry.ttlMs) {
          // Promote back to memory cache
          memoryCache.set(key, entry);
          return entry.response;
        } else {
          sessionStorage.removeItem(`${CACHE_PREFIX}${key}`);
        }
      }
    } catch {
      // sessionStorage unavailable (private browsing, quota exceeded, etc.)
    }
  }

  return null;
}

export function setCachedAIResponse(
  prompt: string,
  response: string,
  ttlMs: number = DEFAULT_TTL_MS
): void {
  const key = hashKey(prompt);
  const entry: CacheEntry = { response, timestamp: Date.now(), ttlMs };

  // Store in memory
  memoryCache.set(key, entry);

  // Store in sessionStorage for persistence across remounts
  if (typeof window !== 'undefined') {
    try {
      sessionStorage.setItem(`${CACHE_PREFIX}${key}`, JSON.stringify(entry));
    } catch {
      // Quota exceeded — clear old entries and retry
      clearExpiredCache();
    }
  }
}

export function clearExpiredCache(): void {
  const now = Date.now();

  // Clear expired memory entries
  for (const [key, entry] of memoryCache.entries()) {
    if (now - entry.timestamp >= entry.ttlMs) {
      memoryCache.delete(key);
    }
  }

  // Clear expired sessionStorage entries
  if (typeof window !== 'undefined') {
    try {
      const keysToRemove: string[] = [];
      for (let i = 0; i < sessionStorage.length; i++) {
        const key = sessionStorage.key(i);
        if (key?.startsWith(CACHE_PREFIX)) {
          const stored = sessionStorage.getItem(key);
          if (stored) {
            const entry: CacheEntry = JSON.parse(stored);
            if (now - entry.timestamp >= entry.ttlMs) {
              keysToRemove.push(key);
            }
          }
        }
      }
      keysToRemove.forEach((k) => sessionStorage.removeItem(k));
    } catch {
      // ignore
    }
  }
}

export function clearAllAICache(): void {
  memoryCache.clear();
  if (typeof window !== 'undefined') {
    try {
      const keysToRemove: string[] = [];
      for (let i = 0; i < sessionStorage.length; i++) {
        const key = sessionStorage.key(i);
        if (key?.startsWith(CACHE_PREFIX)) keysToRemove.push(key);
      }
      keysToRemove.forEach((k) => sessionStorage.removeItem(k));
    } catch {
      // ignore
    }
  }
}
