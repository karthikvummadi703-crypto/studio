{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Extended user information and sustainability metrics.",
      "type": "object",
      "properties": {
        "fullName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "greenPoints": { "type": "number", "description": "Total points earned." },
        "sustainabilityScore": { "type": "number", "description": "0-100 score based on footprint." },
        "level": { "type": "string", "enum": ["Seedling", "Eco Warrior", "Climate Champion", "Planet Guardian"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "completedChallenges": { 
          "type": "array", 
          "items": { "type": "string" },
          "description": "IDs of completed challenges."
        }
      },
      "required": ["fullName", "email", "greenPoints", "sustainabilityScore", "level"]
    },
    "CalculatorRecord": {
      "title": "Calculator Record",
      "description": "A single entry of carbon footprint data.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "totalEmissions": { "type": "number" },
        "breakdown": {
          "type": "object",
          "properties": {
            "transportation": { "type": "number" },
            "energy": { "type": "number" },
            "food": { "type": "number" },
            "lifestyle": { "type": "number" }
          }
        },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "ChallengeProgress": {
      "title": "Challenge Progress",
      "description": "Tracks the current active challenge for a user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "challengeId": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "completed"] },
        "startDate": { "type": "string", "format": "date-time" },
        "completedDate": { "type": "string", "format": "date-time" }
      }
    },
    "Activity": {
      "title": "Activity",
      "description": "Log of user actions and points earned.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string" },
        "description": { "type": "string" },
        "pointsEarned": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "AIConversation": {
      "title": "AI Conversation",
      "description": "Stores a chat session between a user and the AI advisor.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "messages": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "role": { "type": "string", "enum": ["user", "ai"] },
              "text": { "type": "string" },
              "timestamp": { "type": "string", "format": "date-time" }
            }
          }
        },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["email", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile data."
    },
    "/calculator_records/{recordId}": {
      "schema": "CalculatorRecord",
      "description": "User carbon footprint entries."
    },
    "/challenge_progress/{progressId}": {
      "schema": "ChallengeProgress",
      "description": "User progress on specific challenges."
    },
    "/activities/{activityId}": {
      "schema": "Activity",
      "description": "Recent user activities and point logs."
    },
    "/ai_conversations/{conversationId}": {
      "schema": "AIConversation",
      "description": "User AI chat history."
    }
  }
}